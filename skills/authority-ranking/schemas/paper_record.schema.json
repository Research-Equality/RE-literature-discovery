{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuthorityAwarePaperRecord",
  "type": "object",
  "required": [
    "paper_id",
    "title",
    "authors",
    "year",
    "venue",
    "venue_type",
    "doi",
    "citation_count",
    "peer_reviewed",
    "is_preprint",
    "ccf_rank",
    "core_rank",
    "jcr_quartile",
    "impact_factor",
    "cas_quartile",
    "authority_score",
    "relevance_score",
    "citation_score",
    "recency_score",
    "evidence_score",
    "final_score",
    "selection_bucket",
    "ranking_reason",
    "caution_flags",
    "quality_flags"
  ],
  "properties": {
    "paper_id": {"type": "string"},
    "title": {"type": "string"},
    "authors": {"type": "array", "items": {"type": "string"}},
    "year": {"type": ["integer", "null"]},
    "venue": {"type": "string"},
    "venue_type": {"type": "string", "enum": ["conference", "journal", "workshop", "preprint", "other"]},
    "doi": {"type": "string"},
    "citation_count": {"type": "integer"},
    "peer_reviewed": {"type": "boolean"},
    "is_preprint": {"type": "boolean"},
    "ccf_rank": {"type": ["string", "null"], "enum": ["A", "B", "C", null]},
    "core_rank": {"type": ["string", "null"], "enum": ["A*", "A", "B", "C", null]},
    "jcr_quartile": {"type": ["string", "null"], "enum": ["Q1", "Q2", "Q3", "Q4", null]},
    "impact_factor": {"type": ["number", "null"]},
    "cas_quartile": {"type": ["string", "null"], "enum": ["Q1", "Q2", "Q3", "Q4", null]},
    "authority_score": {"type": ["number", "null"]},
    "relevance_score": {"type": ["number", "null"]},
    "citation_score": {"type": ["number", "null"]},
    "recency_score": {"type": ["number", "null"]},
    "evidence_score": {"type": ["number", "null"]},
    "final_score": {"type": ["number", "null"]},
    "selection_bucket": {"type": "string", "enum": ["core", "supporting", "background", "watchlist", "unranked"]},
    "ranking_reason": {"type": "string"},
    "caution_flags": {"type": "array", "items": {"type": "string"}},
    "quality_flags": {"type": "array", "items": {"type": "string"}}
  }
}
