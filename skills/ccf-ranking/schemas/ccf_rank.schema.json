{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CCFRankEnrichment",
  "type": "object",
  "properties": {
    "venue": {"type": "string"},
    "ccf_rank": {"type": ["string", "null"], "enum": ["A", "B", "C", null]},
    "core_rank": {"type": ["string", "null"], "enum": ["A*", "A", "B", "C", null]},
    "ccf_match_type": {"type": "string", "enum": ["exact", "alias", "normalized_abbreviation", "fuzzy", "unresolved"]},
    "ccf_match_confidence": {"type": ["number", "null"]},
    "ccf_source": {"type": "string"},
    "ccf_version": {"type": "string"},
    "ccf_verified_at": {"type": "string"},
    "ccf_warnings": {"type": "array", "items": {"type": "string"}}
  }
}
